/* pages/stats/stats.wxss */
.container {
  padding: 32rpx;
  background-color: var(--background-color);
}

/* 顶部玻璃态日期选择器 */
.picker-card {
  padding: 40rpx;
  border-radius: var(--radius-lg);
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-soft);
}

.month-selector {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 40rpx;
}

.selected-month {
  font-size: 56rpx;
  font-weight: 800;
  color: var(--text-main);
  margin-right: 12rpx;
}

.picker-arrow {
  font-size: 24rpx;
  color: var(--text-sub);
}

.month-summary {
  display: flex;
  justify-content: space-around;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  padding-top: 40rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-label {
  font-size: 24rpx;
  color: var(--text-sub);
  margin-bottom: 8rpx;
}

.summary-value {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--primary-color);
}

/* 图表卡片 */
.chart-card {
  padding: 32rpx;
  margin-bottom: 40rpx;
}

.chart-header {
  margin-bottom: 32rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chart-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-main);
}

.chart-container {
  width: 100%;
  height: 450rpx;
  position: relative;
}

ec-canvas {
  width: 100%;
  height: 100%;
}

.chart-placeholder {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.02);
  border-radius: 16rpx;
  font-size: 24rpx;
  color: var(--text-sub);
}
